# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# URL для webhook (в production)
WEBHOOK_URL=https://yourdomain.com

# URL для Web App (должен быть HTTPS)
WEB_APP_URL=https://yourdomain.com/app

# Telegram ID администраторов (через запятую)
ADMIN_TELEGRAM_ID=your_telegram_id

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=intercity_taxi
DB_USER=postgres
DB_PASSWORD=your_password

# Redis (для кэширования и очередей)
REDIS_HOST=localhost
REDIS_PORT=6379

# Server settings
PORT=3000
NODE_ENV=development

# Настройки системы
DRIVER_OFFLINE_TIMEOUT_HOURS=12
ORDER_ALERT_TIMEOUT_HOURS=2
MAX_BROADCAST_PER_SECOND=25
